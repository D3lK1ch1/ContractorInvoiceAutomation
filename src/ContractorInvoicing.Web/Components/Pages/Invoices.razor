@page "/invoices"
@rendermode InteractiveServer
@using System.Globalization
@using ContractorInvoicing.Domain.Entities
@using ContractorInvoicing.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ContractorInvoicingDbContext> DbFactory
@inject IJSRuntime JS

<PageTitle>Invoices</PageTitle>

<h1>Invoices</h1>

<p>
    <a class="btn btn-outline-secondary" href="/export/invoices.csv">Export All to CSV</a>
</p>

@if (invoices is null)
{
    <p><em>Loading...</em></p>
}
else if (invoices.Count == 0)
{
    <p><em>No invoices yet. <a href="/invoices/new">Create one</a>.</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Invoice #</th>
                <th>Client</th>
                <th>Issue Date</th>
                <th>Due Date</th>
                <th>Status</th>
                <th>Total</th>
                <th>Outstanding</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var invoice in invoices)
            {
                <tr>
                    <td><a href="@($"/invoices/{invoice.Id}")">@invoice.InvoiceNumber</a></td>
                    <td>@invoice.Client?.DisplayName</td>
                    <td>@invoice.IssueDate.ToString("d MMM yyyy")</td>
                    <td>@invoice.DueDate.ToString("d MMM yyyy")</td>
                    <td>@invoice.Status</td>
                    <td>@invoice.Total.ToString("C", AudCulture)</td>
                    <td>@invoice.OutstandingBalance.ToString("C", AudCulture)</td>
                    <td>
                        <a href="@($"/export/invoices/{invoice.Id}.xlsx")">Export XLSX</a>
                        <button type="button" class="btn btn-sm btn-outline-danger ms-2" @onclick="() => DeleteInvoice(invoice.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private static readonly CultureInfo AudCulture = CultureInfo.GetCultureInfo("en-AU");

    private List<Invoice>? invoices;

    protected override async Task OnInitializedAsync()
    {
        await LoadInvoices();
    }

    private async Task LoadInvoices()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        invoices = await db.Invoices
            .Include(i => i.Client)
            .OrderByDescending(i => i.IssueDate)
            .ToListAsync();
    }

    private async Task DeleteInvoice(int id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this invoice? This cannot be undone.");
        if (!confirmed)
            return;

        await using var db = await DbFactory.CreateDbContextAsync();

        var clientId = await db.Invoices.Where(i => i.Id == id).Select(i => i.ClientId).FirstOrDefaultAsync();
        await db.Invoices.Where(i => i.Id == id).ExecuteDeleteAsync();

        var clientHasInvoicesLeft = await db.Invoices.AnyAsync(i => i.ClientId == clientId);
        if (!clientHasInvoicesLeft)
        {
            await db.Clients.Where(c => c.Id == clientId)
                .ExecuteUpdateAsync(s => s.SetProperty(c => c.NextInvoiceSequence, 1));
        }

        await LoadInvoices();
    }
}
